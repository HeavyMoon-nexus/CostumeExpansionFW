<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>espmerge</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>
  <ItemGroup>
    <!-- Mutagen (GPL-3.0-only libraries are NOT involved here; Mutagen is
         Apache-2.0/MIT dual family - fine for a dev-only tool, not shipped). -->
    <PackageReference Include="Mutagen.Bethesda.Skyrim" Version="0.45.0" />
  </ItemGroup>
</Project>
