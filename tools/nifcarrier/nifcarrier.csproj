<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>nifcarrier</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>
  <ItemGroup>
    <!-- ousnius/NiflySharp (GPL-3.0), restorable from nuget.org as package "Nifly".
         Headless NIF read/write; no NifSkope / Blender GUI required. -->
    <PackageReference Include="Nifly" Version="1.0.0" />
  </ItemGroup>
</Project>
